# ═══════════════════════════════════════════════════════════
# Adiptify — Azure App Service Environment Variables
# Copy this file to .env and fill in your values
# In Azure, set these in App Service → Configuration → Application Settings
# ═══════════════════════════════════════════════════════════

# ─── Core Server ───
PORT=8080
NODE_ENV=production

# ─── MongoDB Atlas / Cosmos DB ───
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=adiptify

# ─── Auth ───
JWT_SECRET=<generate-a-strong-secret-here>

# ─── LLM / Ollama (hosted on a VM or local) ───
OLLAMA_BASE_URL=http://<your-ollama-host>:11434
OLLAMA_MODEL=deepseek-r1

# ─── Azure Document Intelligence (for PDF/PPT RAG parsing) ───
DOCUMENT_INTELLIGENCE_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com
DOCUMENT_INTELLIGENCE_API_KEY=<your-key>

# ─── Azure AI Search (for RAG context retrieval) ───
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_INDEX_NAME=adiptify-rag-index
AZURE_SEARCH_API_KEY=<your-key>

# ─── Azure AI Foundry (for agent-level RAG orchestration) ───
AZURE_AI_PROJECT_ENDPOINT=https://<your-project>.services.ai.azure.com
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o-mini

# ─── Redis (optional, for caching) ───
REDIS_URL=redis://localhost:6379
